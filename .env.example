ICEYARD_ENVIRONMENT=local
ICEYARD_DATABASE_URL=sqlite:///./iceyard.db
ICEYARD_CORS_ORIGINS=["http://localhost:3000"]
# Optional regex for additional allowed origins. In local mode, private-LAN origins
# (e.g. http://192.168.x.x:3000) are allowed automatically; set this to override.
# ICEYARD_CORS_ORIGIN_REGEX=^https?://app\.example\.com$
ICEYARD_SESSION_TTL_MINUTES=720
ICEYARD_LOG_LEVEL=INFO
ICEYARD_SECURE_COOKIES=false
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
